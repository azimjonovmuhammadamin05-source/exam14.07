# TaskHub Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env file with real values to git!

# Database Configuration
ConnectionStrings__DefaultConnection=Data Source=taskhub.db

# JWT Settings
JwtSettings__Secret=your-super-secret-jwt-key-minimum-256-bits-long-change-in-production-NOW
JwtSettings__Issuer=TaskHubIssuer
JwtSettings__Audience=TaskHubAudience

# Google OAuth (Optional)
# Get these from https://console.cloud.google.com
Authentication__Google__ClientId=
Authentication__Google__ClientSecret=

# SMTP Email Configuration (for production)
# EmailSettings__SmtpServer=smtp.gmail.com
# EmailSettings__SmtpPort=587
# EmailSettings__SenderEmail=noreply@taskhub.com
# EmailSettings__SenderName=TaskHub
# EmailSettings__Username=your-email@gmail.com
# EmailSettings__Password=your-app-password
# EmailSettings__EnableSSL=true

# SQL Server Configuration (alternative to SQLite)
# ConnectionStrings__DefaultConnection=Server=your-server;Database=TaskHub;User Id=sa;Password=your-password;
