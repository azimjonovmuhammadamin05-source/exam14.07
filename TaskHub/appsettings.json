{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=taskhub.db"
  },
  "JwtSettings": {
    "Issuer": "TaskHubIssuer",
    "Audience": "TaskHubAudience",
    "Secret": "SuperSecretKeyForJwtDontCommitRealOne"
  },
  "Authentication": {
    "Google": {
      "ClientId": "your-google-client-id",
